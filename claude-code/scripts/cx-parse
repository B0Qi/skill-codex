#!/usr/bin/env python3
"""cx-parse — extract session ID and response from Codex JSONL output.

Subcommands:
  session-id   Extract thread_id from first line (O(1) read)
  response     Extract last agent_message response text
  extract      JSON output with session_id + text + metadata
  watch        Block until Codex completes; manage .coord/ lifecycle

Exit codes: 0=ok, 2=not-found/invalid, 3=parse-error, 4=timeout
"""

import argparse
import json
import os
import re
import sys
import time
from contextlib import contextmanager

UUID_RE = re.compile(
    r"^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
)

EXIT_OK = 0
EXIT_NOT_FOUND = 2
EXIT_PARSE_ERROR = 3
EXIT_TIMEOUT = 4


@contextmanager
def open_input(path):
    """Yield a readable file object. stdin when path is None or '-'."""
    if path is None or path == "-":
        yield sys.stdin
    else:
        f = open(path, "r", encoding="utf-8", errors="replace")
        try:
            yield f
        finally:
            f.close()


# ── session-id ───────────────────────────────────────────────────────

def cmd_session_id(args):
    """Read only the first line and extract thread_id."""
    try:
        with open_input(args.file) as f:
            line = f.readline()
            if not line.strip():
                return EXIT_NOT_FOUND
            obj = json.loads(line)
            tid = obj.get("thread_id", "")
            if not tid or not UUID_RE.match(tid):
                return EXIT_NOT_FOUND
            print(tid)
            return EXIT_OK
    except json.JSONDecodeError:
        return EXIT_PARSE_ERROR
    except OSError:
        return EXIT_PARSE_ERROR


# ── response ─────────────────────────────────────────────────────────

def cmd_response(args):
    """Stream line-by-line, keep only the last agent_message text."""
    last = ""
    source_path = args.file or "<stdin>"
    try:
        with open_input(args.file) as f:
            for line in f:
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if obj.get("type") != "item.completed":
                    continue
                item = obj.get("item") or {}
                if item.get("type") != "agent_message":
                    continue
                text = item.get("text") or ""
                if text:
                    last = text
    except OSError:
        return EXIT_PARSE_ERROR

    if not last:
        return EXIT_NOT_FOUND

    cap = args.max_chars
    if cap and len(last) > cap:
        print(
            last[:cap]
            + f"\n[truncated {len(last) - cap} chars"
            + f" — full response in {source_path}]"
        )
    else:
        print(last)
    return EXIT_OK


# ── extract ──────────────────────────────────────────────────────────

def cmd_extract(args):
    """Single-pass extraction: session_id + response as JSON."""
    source_path = args.file

    # --tee: consume stdin → save to file → parse the saved file
    if args.tee:
        if args.file is not None:
            print(
                "error: --tee and FILE are mutually exclusive",
                file=sys.stderr,
            )
            return EXIT_PARSE_ERROR
        source_path = args.tee
        try:
            with open(args.tee, "w", encoding="utf-8") as out:
                for chunk in iter(lambda: sys.stdin.read(8192), ""):
                    out.write(chunk)
        except OSError as e:
            print(f"error: cannot write to {args.tee}: {e}", file=sys.stderr)
            return EXIT_PARSE_ERROR
        args.file = args.tee

    session_id = ""
    last = ""
    first_line = True

    try:
        with open_input(args.file) as f:
            for line in f:
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    first_line = False
                    continue
                if first_line:
                    first_line = False
                    tid = obj.get("thread_id", "")
                    if tid and UUID_RE.match(tid):
                        session_id = tid
                if obj.get("type") != "item.completed":
                    continue
                item = obj.get("item") or {}
                if item.get("type") != "agent_message":
                    continue
                text = item.get("text") or ""
                if text:
                    last = text
    except OSError:
        return EXIT_PARSE_ERROR

    truncated = False
    cap = args.max_chars
    if cap and len(last) > cap:
        last = last[:cap]
        truncated = True

    result = {
        "session_id": session_id,
        "text": last,
        "text_truncated": truncated,
    }
    if source_path:
        result["metadata"] = {"source": source_path}

    print(json.dumps(result))
    return EXIT_OK if (session_id or last) else EXIT_NOT_FOUND


# ── watch ────────────────────────────────────────────────────────

def _write_json_atomic(path, data):
    """Write JSON to path atomically via tmp+rename."""
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        tmp = path + ".tmp"
        with open(tmp, "w", encoding="utf-8") as f:
            json.dump(data, f)
        os.rename(tmp, path)
    except OSError:
        pass


def _remove_silent(path):
    if path is None:
        return
    try:
        os.unlink(path)
    except OSError:
        pass


def _pid_alive(pid):
    if pid is None:
        return True  # no PID to track — assume alive
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        return False


def _now_iso():
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())


def cmd_watch(args):
    """Block until Codex completes. Manage .coord/ running/done/failed lifecycle."""
    jsonl_path = args.file
    pid = args.pid
    timeout = args.timeout or 600
    cap = args.max_chars
    coord_id = args.coord_id
    coord_dir = args.coord_dir or ".coord"
    interval = args.interval or 2

    # State file paths (None if no coord_id)
    running_f = (
        os.path.join(coord_dir, "running", f"{coord_id}.json")
        if coord_id
        else None
    )
    done_f = (
        os.path.join(coord_dir, "done", f"{coord_id}.json")
        if coord_id
        else None
    )
    failed_f = (
        os.path.join(coord_dir, "failed", f"{coord_id}.json")
        if coord_id
        else None
    )

    start = time.time()
    session_id = ""
    file_pos = 0  # track read position for efficient tailing
    token_usage = {}
    last_agent_message = ""  # track latest agent_message for Responses API format

    def update_heartbeat():
        if not running_f:
            return
        _write_json_atomic(running_f, {
            "coord_id": coord_id,
            "status": "running",
            "session_id": session_id,
            "pid": pid,
            "elapsed_seconds": round(time.time() - start, 1),
            "last_active": _now_iso(),
        })

    def scan_events():
        """Read new JSONL lines from last position. Return result dict or None."""
        nonlocal session_id, file_pos, token_usage, last_agent_message

        try:
            with open(jsonl_path, "r", encoding="utf-8", errors="replace") as f:
                f.seek(file_pos)
                new_lines = f.readlines()
                file_pos = f.tell()
        except FileNotFoundError:
            return None

        for line in new_lines:
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue

            # Session ID from first event (thread.started)
            if not session_id:
                tid = obj.get("thread_id", "")
                if tid and UUID_RE.match(tid):
                    session_id = tid

            top_type = obj.get("type", "")
            payload = obj.get("payload") or obj
            ev_type = payload.get("type", "")

            # Capture token usage — legacy format (event_msg/token_count)
            if ev_type == "token_count":
                info = payload.get("info", {})
                token_usage = info.get("total_token_usage", token_usage)

            # Capture token usage — Responses API format (turn.completed)
            if top_type == "turn.completed":
                usage = obj.get("usage")
                if usage:
                    token_usage = usage

            # Track latest agent_message — Responses API format
            if top_type == "item.completed":
                item = obj.get("item") or {}
                if item.get("type") == "agent_message":
                    last_agent_message = item.get("text", "")

            # ── Completion detection ─────────────────────────

            completed_response = None

            # Legacy completion: event_msg/task_complete
            if ev_type == "task_complete":
                completed_response = payload.get("last_agent_message", "")

            # Responses API completion: turn.completed
            if top_type == "turn.completed":
                completed_response = last_agent_message

            if completed_response is not None:
                response = completed_response
                context_truncated = False
                if cap and len(response) > cap:
                    response = response[:cap]
                    context_truncated = True
                output_tokens = (token_usage or {}).get("output_tokens", 0)
                return {
                    "status": "completed",
                    "session_id": session_id,
                    "response": response,
                    "response_truncated": context_truncated,
                    "output_tokens": output_tokens,
                    "elapsed_seconds": round(time.time() - start, 1),
                    "token_usage": token_usage,
                }

        return None

    def finish(result, terminal_dir_f):
        """Write terminal state file, remove running file, print result."""
        if terminal_dir_f:
            _write_json_atomic(terminal_dir_f, {
                "coord_id": coord_id,
                "status": result["status"],
                "session_id": session_id,
                "finished_at": _now_iso(),
                "elapsed_seconds": result["elapsed_seconds"],
                "token_usage": token_usage,
            })
        _remove_silent(running_f)
        print(json.dumps(result))

    # ── Main loop ────────────────────────────────────────────────

    # Wait for JSONL file to appear (Codex may take a moment to start)
    wait_start = time.time()
    while not os.path.exists(jsonl_path):
        if time.time() - wait_start > 30:
            result = {
                "status": "error",
                "error": f"JSONL file not created after 30s: {jsonl_path}",
                "session_id": "",
                "elapsed_seconds": round(time.time() - start, 1),
            }
            print(json.dumps(result))
            return EXIT_NOT_FOUND
        time.sleep(0.5)

    update_heartbeat()

    while True:
        elapsed = time.time() - start

        # Check JSONL for completion
        result = scan_events()
        if result:
            finish(result, done_f)
            return EXIT_OK

        # Check timeout
        if elapsed > timeout:
            result = {
                "status": "timeout",
                "session_id": session_id,
                "elapsed_seconds": round(elapsed, 1),
            }
            # Keep running_f — session may still be resumable
            print(json.dumps(result))
            return EXIT_TIMEOUT

        # Check if process died
        if not _pid_alive(pid):
            # Grace period — final events may not be flushed yet
            time.sleep(1)
            result = scan_events()
            if result:
                finish(result, done_f)
                return EXIT_OK

            # Process died without task_complete
            result = {
                "status": "crashed",
                "session_id": session_id,
                "elapsed_seconds": round(elapsed, 1),
            }
            finish(result, failed_f)
            return EXIT_NOT_FOUND

        update_heartbeat()
        time.sleep(interval)


# ── CLI ──────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="cx-parse",
        description="Extract session ID and response from Codex JSONL output.",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    # session-id
    p_sid = sub.add_parser(
        "session-id", help="Extract session ID (first line only)"
    )
    p_sid.add_argument(
        "file", nargs="?", default=None, help="JSONL file (default: stdin)"
    )

    # response
    p_resp = sub.add_parser(
        "response", help="Extract last agent response"
    )
    p_resp.add_argument(
        "file", nargs="?", default=None, help="JSONL file (default: stdin)"
    )
    p_resp.add_argument(
        "--max-chars",
        type=int,
        default=None,
        help="Truncate response to N chars",
    )

    # extract
    p_ext = sub.add_parser(
        "extract", help="Extract session_id + response as JSON"
    )
    p_ext.add_argument(
        "file", nargs="?", default=None, help="JSONL file (default: stdin)"
    )
    p_ext.add_argument(
        "--max-chars",
        type=int,
        default=None,
        help="Truncate response to N chars",
    )
    p_ext.add_argument(
        "--tee",
        metavar="PATH",
        default=None,
        help="Save stdin to PATH, then parse the saved file",
    )

    # watch
    p_watch = sub.add_parser(
        "watch",
        help="Block until Codex completes; manage .coord/ lifecycle",
    )
    p_watch.add_argument(
        "file", help="JSONL file being written by codex exec"
    )
    p_watch.add_argument(
        "--pid",
        type=int,
        default=None,
        help="Codex process PID to monitor",
    )
    p_watch.add_argument(
        "--timeout",
        type=int,
        default=600,
        help="Max wait time in seconds (default: 600)",
    )
    p_watch.add_argument(
        "--max-chars",
        type=int,
        default=None,
        help="Truncate response to N chars",
    )
    p_watch.add_argument(
        "--coord-id",
        default=None,
        help="Coord ID for .coord/ state file management",
    )
    p_watch.add_argument(
        "--coord-dir",
        default=".coord",
        help="Path to .coord/ directory (default: .coord)",
    )
    p_watch.add_argument(
        "--interval",
        type=int,
        default=2,
        help="Poll interval in seconds (default: 2)",
    )

    args = parser.parse_args()

    if args.command == "session-id":
        sys.exit(cmd_session_id(args))
    elif args.command == "response":
        sys.exit(cmd_response(args))
    elif args.command == "extract":
        sys.exit(cmd_extract(args))
    elif args.command == "watch":
        sys.exit(cmd_watch(args))


if __name__ == "__main__":
    main()
