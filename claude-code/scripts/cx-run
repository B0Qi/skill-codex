#!/bin/bash
# cx-run — launch Codex and watch to completion in one command.
#
# Handles the full lifecycle: launch → session registry → watch → notify.
# Designed for Claude Code's run_in_background — zero polling, pure notification.
#
# Usage:
#   cx-run [OPTIONS] -- codex exec --json --yolo ... "$PROMPT"
#   cx-run --resume SESSION_ID [OPTIONS]
#
# Options:
#   --coord-id ID       Coord ID (default: cx_<timestamp>)
#   --coord-dir DIR     .coord directory (default: .coord)
#   --timeout SECONDS   Max wait time (default: 600)
#   --max-chars N       Truncate response (default: 12288)
#   --resume SID        Resume a previous session instead of launching new
#
# Output: JSON to stdout on completion (from cx-parse watch)
# Exit codes: 0=completed, 2=crashed/not-found, 4=timeout

set -uo pipefail
# NOTE: no `set -e` — cx-parse watch exits non-zero on crash/timeout,
# and we must still run the registry update below.

COORD_ID="cx_$(date +%s)"
COORD_DIR=".coord"
TIMEOUT=600
MAX_CHARS=12288
RESUME_SID=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --coord-id)  COORD_ID="$2"; shift 2;;
    --coord-dir) COORD_DIR="$2"; shift 2;;
    --timeout)   TIMEOUT="$2";   shift 2;;
    --max-chars) MAX_CHARS="$2";  shift 2;;
    --resume)    RESUME_SID="$2"; shift 2;;
    --)          shift; break;;
    *)           break;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CX="$SCRIPT_DIR/cx-parse"

mkdir -p "$COORD_DIR/running" "$COORD_DIR/done" "$COORD_DIR/failed"

# ── Resume mode ─────────────────────────────────────────────────
if [ -n "$RESUME_SID" ]; then
  # Look up original command from registry
  ORIG_CMD=""
  if [ -f "$COORD_DIR/sessions.jsonl" ]; then
    ORIG_CMD="$(grep "\"session_id\":\"$RESUME_SID\"" "$COORD_DIR/sessions.jsonl" \
      | grep '"command"' | tail -1 \
      | python3 -c 'import sys,json; print(json.loads(sys.stdin.readline()).get("command",""))' 2>/dev/null)"
  fi

  # Build resume command — inherit --json and --yolo from original
  JSONL="$(mktemp -t codex.XXXXXX.jsonl)"
  codex exec --json --yolo --skip-git-repo-check --resume "$RESUME_SID" \
    -p "Continue from where you left off. Complete the remaining work." \
    >"$JSONL" 2>/dev/null &
  CMD_PID=$!

  # Extract new session ID (resume may create a new one or reuse)
  SESSION_ID="$RESUME_SID"
  for _i in $(seq 1 60); do
    if [ -s "$JSONL" ]; then
      NEW_SID="$("$CX" session-id "$JSONL" 2>/dev/null)" && [ -n "$NEW_SID" ] && SESSION_ID="$NEW_SID" && break
    fi
    sleep 0.5
  done

  # Register resume
  printf '{"agent":"codex","coord_id":"%s","session_id":"%s","resumed_from":"%s","status":"running","cwd":"%s","created_at":"%s"}\n' \
    "$COORD_ID" "$SESSION_ID" "$RESUME_SID" "$(pwd)" "$(date -Iseconds)" \
    >> "$COORD_DIR/sessions.jsonl" 2>/dev/null || true

  # Watch
  "$CX" watch "$JSONL" \
    --pid "$CMD_PID" \
    --coord-id "$COORD_ID" \
    --coord-dir "$COORD_DIR" \
    --max-chars "$MAX_CHARS" \
    --timeout "$TIMEOUT"
  EXIT_CODE=$?

  # Update registry
  FINAL_STATUS="done"
  [ -f "$COORD_DIR/failed/$COORD_ID.json" ] && FINAL_STATUS="failed"
  [ $EXIT_CODE -eq 4 ] && FINAL_STATUS="timeout"

  printf '{"agent":"codex","coord_id":"%s","session_id":"%s","status":"%s","updated_at":"%s"}\n' \
    "$COORD_ID" "$SESSION_ID" "$FINAL_STATUS" "$(date -Iseconds)" \
    >> "$COORD_DIR/sessions.jsonl" 2>/dev/null || true

  exit $EXIT_CODE
fi

# ── Normal launch mode ──────────────────────────────────────────

if [ $# -eq 0 ]; then
  echo '{"status":"error","error":"No command. Usage: cx-run [OPTIONS] -- codex exec ..."}' >&2
  exit 1
fi

JSONL="$(mktemp -t codex.XXXXXX.jsonl)"

# ── Launch ───────────────────────────────────────────────────────
# Command after -- is expected to include --json and write JSONL to stdout.
"$@" >"$JSONL" 2>/dev/null &
CMD_PID=$!

# ── Extract session ID (max 30s) ────────────────────────────────
SESSION_ID=""
for _i in $(seq 1 60); do
  if [ -s "$JSONL" ]; then
    SESSION_ID="$("$CX" session-id "$JSONL" 2>/dev/null)" && [ -n "$SESSION_ID" ] && break
  fi
  sleep 0.5
done

# ── Register session (with original command for resume) ─────────
# Escape the command for JSON storage
CMD_JSON="$(printf '%s' "$*" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null || echo '""')"
printf '{"agent":"codex","coord_id":"%s","session_id":"%s","status":"running","command":%s,"cwd":"%s","mode":"serial","created_at":"%s"}\n' \
  "$COORD_ID" "$SESSION_ID" "$CMD_JSON" "$(pwd)" "$(date -Iseconds)" \
  >> "$COORD_DIR/sessions.jsonl" 2>/dev/null || true

# ── Watch — blocks until completion ─────────────────────────────
"$CX" watch "$JSONL" \
  --pid "$CMD_PID" \
  --coord-id "$COORD_ID" \
  --coord-dir "$COORD_DIR" \
  --max-chars "$MAX_CHARS" \
  --timeout "$TIMEOUT"
EXIT_CODE=$?

# ── Update registry ─────────────────────────────────────────────
FINAL_STATUS="done"
[ -f "$COORD_DIR/failed/$COORD_ID.json" ] && FINAL_STATUS="failed"
[ $EXIT_CODE -eq 4 ] && FINAL_STATUS="timeout"

printf '{"agent":"codex","coord_id":"%s","session_id":"%s","status":"%s","updated_at":"%s"}\n' \
  "$COORD_ID" "$SESSION_ID" "$FINAL_STATUS" "$(date -Iseconds)" \
  >> "$COORD_DIR/sessions.jsonl" 2>/dev/null || true

exit $EXIT_CODE
